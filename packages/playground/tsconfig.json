{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "tsBuildInfoFile": "../../node_modules/.cache/tsbuildinfo/playground.tsbuildinfo",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
