{
  "name": "@seqlok/core",
  "version": "0.3.0-next.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "source": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "bench": "vitest bench --reporter=verbose --run",
    "bench:format": "tsx scripts/format-bench.ts",
    "bench:report": "pnpm run bench && pnpm run bench:format",
    "bench:charts": "python3 scripts/plot_bench.py",
    "lint": "eslint src tests scripts",
    "lint:fix": "eslint src tests scripts --fix",
    "format": "prettier --ignore-path ../../.prettierignore --write .",
    "clean": "rimraf dist .eslintcache node_modules/.vite node_modules/.cache pnpm-debug.log",
    "purge": "pnpm run clean && rimraf node_modules",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:types": "pnpm --workspace-root test:types",
    "build": "pnpm run clean && vite build && rollup -c rollup.dts.config.mts",
    "dev": "pnpm run test:watch"
  },
  "dependencies": {
    "@seqlok/base": "workspace:*",
    "@seqlok/primitives": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-import": "catalog:",
    "eslint-plugin-regex": "catalog:",
    "fast-check": "catalog:",
    "globals": "catalog:",
    "rollup": "catalog:",
    "rollup-plugin-dts": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
