{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "tsBuildInfoFile": "../../node_modules/.cache/tsbuildinfo/core-eslint.tsbuildinfo"
  },
  "include": [
    "src/**/*",
    "tests/**/*",
    "bench/**/*",
    "scripts/**/*",
    "*.config.ts",
    "vite.config.ts",
    "rollup.*.config.{js,ts,mts}"
  ],
  "exclude": ["dist", "node_modules"]
}
