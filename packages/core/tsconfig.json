{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "tsBuildInfoFile": "../../node_modules/.cache/tsbuildinfo/core.tsbuildinfo",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["vitest/globals", "node"],
    "paths": {}
  },
  "include": ["src/**/*"],
  "exclude": [
    "dist",
    "node_modules",
    "tests_legacy",
    "tests_next",
    "tests",
    "bench",
    "scripts",
    "*.config.ts",
    "vitest.config.ts"
  ]
}
