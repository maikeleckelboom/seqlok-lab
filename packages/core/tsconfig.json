{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "./",
    "outDir": "./dist",
    "tsBuildInfoFile": "./node_modules/.cache/core.tsbuildinfo",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["vitest/globals", "node"]
  },
  "include": ["src/**/*"],
  "exclude": [
    "dist",
    "node_modules",
    "tests/**/*",
    "bench/**/*",
    "scripts/**/*",
    "**/*.test.ts",
    "**/*.spec.ts",
    "*.config.ts",
    "vitest.config.*"
  ]
}
