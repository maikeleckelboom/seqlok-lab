{
  "name": "@seqlok/schema",
  "version": "0.3.0-next.0",
  "description": "Canonical authored spec contract for Seqlok. Structural validation, normalization, and JSON Schema export.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "source": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./spec-ast/v1.json": "./spec-ast/v1.json",
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*",
    "spec-ast/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build && rollup -c rollup.dts.config.mts",
    "clean": "rimraf dist .eslintcache pnpm-debug.log",
    "purge": "pnpm run clean && rimraf node_modules",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --ignore-path ../../.prettierignore --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:types": "pnpm --workspace-root test:types",
    "dev": "pnpm run test:watch"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "eslint-import-resolver-typescript": "catalog:",
    "eslint-plugin-import": "catalog:",
    "eslint-plugin-regex": "catalog:",
    "fast-check": "catalog:",
    "globals": "catalog:",
    "rimraf": "catalog:",
    "rollup": "catalog:",
    "rollup-plugin-dts": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
