{
  "name": "@seqlok/foundation",
  "version": "0.3.0-next.0",
  "description": "Seqlok error algebra, invariants, and shared protocol shapes.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "source": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist .eslintcache node_modules/.vite node_modules/.cache pnpm-debug.log",
    "purge": "pnpm run clean && rimraf node_modules",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --ignore-path ../../.prettierignore --write .",
    "test": "vitest run || echo \"(no tests in @seqlok/foundation yet)\"",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "bench": "vitest bench --run",
    "bench:watch": "vitest bench",
    "test:types": "tsc -b --noEmit --pretty"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "eslint-import-resolver-typescript": "catalog:",
    "eslint-plugin-import": "catalog:",
    "eslint-plugin-regex": "catalog:",
    "fast-check": "catalog:",
    "globals": "catalog:",
    "rimraf": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  }
}
