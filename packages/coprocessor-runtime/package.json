{
  "name": "@seqlok/coprocessor-runtime",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "THIRD_PARTY_NOTICES.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./protocol": {
      "types": "./dist/protocol.d.ts",
      "import": "./dist/protocol.js"
    },
    "./mount": {
      "types": "./dist/mount.d.ts",
      "import": "./dist/mount.js"
    },
    "./kernel": {
      "types": "./dist/kernel.d.ts",
      "import": "./dist/kernel.js"
    }
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "check": "tsc -p tsconfig.json --noEmit",
    "build": "vite build && rollup -c rollup.dts.config.mts",
    "clean": "rimraf dist .eslintcache pnpm-debug.log",
    "purge": "pnpm run clean && rimraf node_modules",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --ignore-path ../../.prettierignore --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:types": "pnpm --workspace-root test:types",
    "bench": "vitest bench --reporter=verbose --run",
    "dev": "pnpm run test:watch"
  },
  "devDependencies": {
    "rollup": "^4.54.0",
    "rollup-plugin-dts": "^6.1.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.13",
    "@types/audioworklet": "^0.0.92"
  },
  "dependencies": {
    "@seqlok/base": "workspace:*"
  }
}
