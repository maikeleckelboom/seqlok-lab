{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HotSwapTestVectors",
  "description": "Conformance test vectors for @seqlok/hotswap protocol implementations",
  "version": "0.1.0",
  "vectors": [
    {
      "name": "minimal_swap_no_prewarm",
      "description": "Simplest possible swap: zero prewarm, minimal fade",
      "ticket": {
        "ticketId": 1,
        "engineKind": 1,
        "atFrame": 0,
        "fadeFrames": 128,
        "preWarmBlocks": 0
      },
      "blockFrames": 128,
      "noneKindSentinel": 255,
      "initialActiveKind": 0,
      "expectedSteps": [
        {
          "inputActiveKind": 0,
          "inputNextKind": 1,
          "expectedPhase": "spawn",
          "expectedKind": "runCurrentOnly",
          "expectedProgress": 0.0,
          "statePhaseAfter": "prime"
        },
        {
          "inputActiveKind": 0,
          "inputNextKind": 1,
          "expectedPhase": "prime",
          "expectedKind": "runCurrentOnly",
          "statePhaseAfter": "crossfade"
        },
        {
          "inputActiveKind": 0,
          "inputNextKind": 1,
          "expectedPhase": "crossfade",
          "expectedKind": "runBothForCrossfade",
          "statePhaseAfter": "retire"
        },
        {
          "inputActiveKind": 0,
          "inputNextKind": 1,
          "expectedPhase": "retire",
          "expectedKind": "retireNow",
          "statePhaseAfter": "idle"
        }
      ]
    },
    {
      "name": "swap_with_prewarm",
      "description": "Swap with 3 prewarm blocks",
      "ticket": {
        "ticketId": 42,
        "engineKind": 2,
        "atFrame": 48000,
        "fadeFrames": 256,
        "preWarmBlocks": 3
      },
      "blockFrames": 128,
      "noneKindSentinel": 255,
      "initialActiveKind": 1,
      "expectedSteps": [
        {
          "inputActiveKind": 1,
          "inputNextKind": 2,
          "expectedPhase": "spawn",
          "expectedKind": "runCurrentOnly",
          "statePhaseAfter": "prime"
        },
        {
          "inputActiveKind": 1,
          "inputNextKind": 2,
          "expectedPhase": "prime",
          "expectedKind": "runCurrentOnly",
          "statePhaseAfter": "prewarm"
        },
        {
          "inputActiveKind": 1,
          "inputNextKind": 2,
          "expectedPhase": "prewarm",
          "expectedKind": "runCurrentAndPrewarmNext",
          "comment": "prewarmBlocksRemaining: 3 -> 2",
          "statePhaseAfter": "prewarm"
        },
        {
          "inputActiveKind": 1,
          "inputNextKind": 2,
          "expectedPhase": "prewarm",
          "expectedKind": "runCurrentAndPrewarmNext",
          "comment": "prewarmBlocksRemaining: 2 -> 1",
          "statePhaseAfter": "prewarm"
        },
        {
          "inputActiveKind": 1,
          "inputNextKind": 2,
          "expectedPhase": "prewarm",
          "expectedKind": "runCurrentAndPrewarmNext",
          "comment": "prewarmBlocksRemaining: 1 -> 0, transition to crossfade",
          "statePhaseAfter": "crossfade"
        },
        {
          "inputActiveKind": 1,
          "inputNextKind": 2,
          "expectedPhase": "crossfade",
          "expectedKind": "runBothForCrossfade",
          "comment": "fadeFramesRemaining: 256 -> 128",
          "statePhaseAfter": "crossfade"
        },
        {
          "inputActiveKind": 1,
          "inputNextKind": 2,
          "expectedPhase": "crossfade",
          "expectedKind": "runBothForCrossfade",
          "comment": "fadeFramesRemaining: 128 -> 0, transition to retire",
          "statePhaseAfter": "retire"
        },
        {
          "inputActiveKind": 1,
          "inputNextKind": 2,
          "expectedPhase": "retire",
          "expectedKind": "retireNow",
          "statePhaseAfter": "idle"
        }
      ]
    },
    {
      "name": "long_crossfade",
      "description": "Crossfade spanning multiple blocks with non-aligned frame count",
      "ticket": {
        "ticketId": 100,
        "engineKind": 0,
        "atFrame": 0,
        "fadeFrames": 500,
        "preWarmBlocks": 0
      },
      "blockFrames": 128,
      "noneKindSentinel": 255,
      "initialActiveKind": 1,
      "expectedSteps": [
        {
          "inputActiveKind": 1,
          "inputNextKind": 0,
          "expectedPhase": "spawn",
          "expectedKind": "runCurrentOnly",
          "statePhaseAfter": "prime"
        },
        {
          "inputActiveKind": 1,
          "inputNextKind": 0,
          "expectedPhase": "prime",
          "expectedKind": "runCurrentOnly",
          "statePhaseAfter": "crossfade"
        },
        {
          "inputActiveKind": 1,
          "inputNextKind": 0,
          "expectedPhase": "crossfade",
          "expectedKind": "runBothForCrossfade",
          "comment": "fadeFramesRemaining: 500 -> 372",
          "statePhaseAfter": "crossfade"
        },
        {
          "inputActiveKind": 1,
          "inputNextKind": 0,
          "expectedPhase": "crossfade",
          "expectedKind": "runBothForCrossfade",
          "comment": "fadeFramesRemaining: 372 -> 244",
          "statePhaseAfter": "crossfade"
        },
        {
          "inputActiveKind": 1,
          "inputNextKind": 0,
          "expectedPhase": "crossfade",
          "expectedKind": "runBothForCrossfade",
          "comment": "fadeFramesRemaining: 244 -> 116",
          "statePhaseAfter": "crossfade"
        },
        {
          "inputActiveKind": 1,
          "inputNextKind": 0,
          "expectedPhase": "crossfade",
          "expectedKind": "runBothForCrossfade",
          "comment": "fadeFramesRemaining: 116 -> 0 (clamped), transition to retire",
          "statePhaseAfter": "retire"
        },
        {
          "inputActiveKind": 1,
          "inputNextKind": 0,
          "expectedPhase": "retire",
          "expectedKind": "retireNow",
          "statePhaseAfter": "idle"
        }
      ]
    },
    {
      "name": "idle_state_returns_idle",
      "description": "Calling step on idle state with no ticket returns idle decision",
      "ticket": null,
      "blockFrames": 128,
      "noneKindSentinel": 255,
      "initialActiveKind": 0,
      "initialState": {
        "phase": "idle",
        "hasTicket": false
      },
      "expectedSteps": [
        {
          "inputActiveKind": 0,
          "inputNextKind": 255,
          "expectedPhase": "idle",
          "expectedKind": "idle",
          "expectedTicketId": 0,
          "expectedNextEngineKind": 255,
          "statePhaseAfter": "idle"
        }
      ]
    },
    {
      "name": "progress_monotonic",
      "description": "Verify progress never decreases",
      "ticket": {
        "ticketId": 7,
        "engineKind": 1,
        "atFrame": 0,
        "fadeFrames": 512,
        "preWarmBlocks": 2
      },
      "blockFrames": 128,
      "noneKindSentinel": 255,
      "initialActiveKind": 0,
      "assertions": [
        {
          "type": "progress_monotonic",
          "description": "Each step's progress >= previous step's progress"
        }
      ],
      "expectedSteps": [
        { "expectedPhase": "spawn", "progressMustBeGreaterThanOrEqual": 0 },
        { "expectedPhase": "prime", "progressMustBeGreaterThanOrEqual": 0 },
        { "expectedPhase": "prewarm", "progressMustBeGreaterThanOrEqual": 0 },
        { "expectedPhase": "prewarm", "progressMustBeGreaterThanOrEqual": 0 },
        { "expectedPhase": "crossfade", "progressMustBeGreaterThanOrEqual": 0 },
        { "expectedPhase": "crossfade", "progressMustBeGreaterThanOrEqual": 0 },
        { "expectedPhase": "crossfade", "progressMustBeGreaterThanOrEqual": 0 },
        { "expectedPhase": "crossfade", "progressMustBeGreaterThanOrEqual": 0 },
        { "expectedPhase": "retire", "progressMustBeGreaterThanOrEqual": 0 }
      ]
    },
    {
      "name": "exact_single_block_fade",
      "description": "Fade that completes in exactly one block",
      "ticket": {
        "ticketId": 99,
        "engineKind": 1,
        "atFrame": 0,
        "fadeFrames": 128,
        "preWarmBlocks": 0
      },
      "blockFrames": 128,
      "noneKindSentinel": 255,
      "initialActiveKind": 0,
      "expectedSteps": [
        { "expectedPhase": "spawn", "expectedKind": "runCurrentOnly", "statePhaseAfter": "prime" },
        { "expectedPhase": "prime", "expectedKind": "runCurrentOnly", "statePhaseAfter": "crossfade" },
        { 
          "expectedPhase": "crossfade", 
          "expectedKind": "runBothForCrossfade", 
          "comment": "fadeFramesRemaining: 128 -> 0",
          "statePhaseAfter": "retire" 
        },
        { "expectedPhase": "retire", "expectedKind": "retireNow", "statePhaseAfter": "idle" }
      ]
    },
    {
      "name": "sub_block_fade",
      "description": "Fade shorter than one block still takes one crossfade step",
      "ticket": {
        "ticketId": 88,
        "engineKind": 1,
        "atFrame": 0,
        "fadeFrames": 64,
        "preWarmBlocks": 0
      },
      "blockFrames": 128,
      "noneKindSentinel": 255,
      "initialActiveKind": 0,
      "expectedSteps": [
        { "expectedPhase": "spawn", "expectedKind": "runCurrentOnly", "statePhaseAfter": "prime" },
        { "expectedPhase": "prime", "expectedKind": "runCurrentOnly", "statePhaseAfter": "crossfade" },
        { 
          "expectedPhase": "crossfade", 
          "expectedKind": "runBothForCrossfade", 
          "comment": "fadeFramesRemaining: 64 -> 0 (clamped at 0)",
          "statePhaseAfter": "retire" 
        },
        { "expectedPhase": "retire", "expectedKind": "retireNow", "statePhaseAfter": "idle" }
      ]
    }
  ],
  "invariants": [
    {
      "name": "AtMostTwoEngines",
      "description": "nextEngineActive implies phase is not idle"
    },
    {
      "name": "NoGapDuringCrossfade",
      "description": "During crossfade phase, both engines must be run"
    },
    {
      "name": "NoOrphanedNextEngine",
      "description": "nextEngineActive implies hasTicket"
    },
    {
      "name": "PhaseTicketConsistency",
      "description": "phase != idle implies hasTicket"
    },
    {
      "name": "ProgressMonotonic",
      "description": "progress never decreases between steps"
    },
    {
      "name": "EventuallyIdle",
      "description": "Every initialized swap eventually reaches idle phase"
    }
  ]
}
