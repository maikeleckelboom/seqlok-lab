{
  "name": "@seqlok/hotswap",
  "version": "0.1.0",
  "description": "Engine lifecycle and hot-swap protocol on top of Seqlok.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "source": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build && rollup -c rollup.dts.config.mts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --ignore-path ../../.prettierignore --write .",
    "clean": "rimraf dist .eslintcache node_modules/.vite node_modules/.cache pnpm-debug.log",
    "test:types": "pnpm --workspace-root test:types",
    "dev": "pnpm run test:watch"
  },
  "dependencies": {
    "@seqlok/base": "workspace:*",
    "@seqlok/primitives": "workspace:*",
    "@seqlok/core": "workspace:*",
    "@seqlok/commands": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "eslint-import-resolver-typescript": "catalog:",
    "eslint-plugin-import": "catalog:",
    "eslint-plugin-regex": "catalog:",
    "fast-check": "catalog:",
    "globals": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vite": "catalog:",
    "rollup": "catalog:",
    "rollup-plugin-dts": "catalog:",
    "vitest": "catalog:"
  }
}
