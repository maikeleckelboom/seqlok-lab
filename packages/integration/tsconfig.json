{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "tsBuildInfoFile": "../../node_modules/.cache/tsbuildinfo/integration.tsbuildinfo",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["node"],
    "paths": {}
  },
  "include": ["src/**/*"],
  "exclude": [
    "dist",
    "node_modules",
    "tests",
    "bench",
    "scripts",
    "*.config.ts",
    "vitest.config.ts",
    "vite.config.ts",
    "rollup.*.config.{js,ts,mts}"
  ]
}
