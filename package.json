{
  "name": "seqlok",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "prepare": "simple-git-hooks",
    "dev": "concurrently -n types,core \"pnpm dev:types\" \"pnpm -F @seqlok/core run dev\"",
    "dev:ui": "concurrently -n types,core,app \"pnpm dev:types\" \"pnpm -F @seqlok/core run dev\" \"pnpm -F @seqlok/playground run dev\"",
    "dev:types": "tsc -p tsconfig.workspace.json --noEmit --watch",
    "test:types": "tsc -p tsconfig.workspace.json --noEmit",
    "build": "pnpm -r -F \"@seqlok/*\" run build",
    "test": "pnpm -r -F \"@seqlok/*\" run test",
    "test:core": "pnpm -F @seqlok/core run test",
    "test:cov": "pnpm -F @seqlok/core run test:cov",
    "test:watch": "pnpm -F @seqlok/core run test:watch",
    "bench:core": "pnpm -F @seqlok/core run bench",
    "bench:core:report": "pnpm -F @seqlok/core run bench:report",
    "bench": "pnpm run bench:core",
    "bench:report": "pnpm run bench:core:report",
    "bench:hotswap": "pnpm -F @seqlok/hotswap run bench",
    "lint": "pnpm -r -F \"@seqlok/*\" run lint",
    "lint:fix": "pnpm -r -F \"@seqlok/*\" run lint:fix",
    "lint:md": "markdownlint-cli2",
    "lint:md:fix": "markdownlint-cli2 --fix",
    "check": "pnpm test:types && pnpm test && pnpm lint",
    "verify": "pnpm clean && pnpm build && pnpm check",
    "format": "prettier --ignore-path .prettierignore --write .",
    "clean": "pnpm -r -F \"@seqlok/*\" run clean && rimraf .eslintcache pnpm-debug.log",
    "clean:caches": "rimraf node_modules/.cache node_modules/.vite",
    "purge": "pnpm run clean && pnpm run clean:caches && rimraf node_modules packages/**/node_modules",
    "commitlint": "commitlint --color",
    "tla:fetch": "tsx scripts/tla/fetch-tools.ts",
    "tla:hotswap": "tsx scripts/tla/run-hotswap.ts invonly",
    "tla:hotswap:full": "tsx scripts/tla/run-hotswap.ts full -nowarning",
    "schema:errors:json": "pnpm -F @seqlok/introspect run errors:registry:schema",
    "schema:errors:snapshots": "pnpm -F @seqlok/introspect run errors:registry:schema:snapshots",
    "tsc": "echo \"Use 'pnpm dev:types' or 'pnpm -F @seqlok/<pkg> run build' – direct 'tsc' is disabled\" && exit 1",
    "support": "tsx scripts/support/seqlok-support.ts"
  },
  "simple-git-hooks": {
    "commit-msg": "pnpm commitlint --edit $1"
  },
  "packageManager": "pnpm@10.24.0",
  "devDependencies": {
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@commitlint/types": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "concurrently": "catalog:",
    "eslint": "catalog:",
    "eslint-import-resolver-typescript": "catalog:",
    "eslint-plugin-import": "catalog:",
    "eslint-plugin-regex": "catalog:",
    "fast-check": "catalog:",
    "globals": "catalog:",
    "happy-dom": "catalog:",
    "markdownlint-cli2": "catalog:",
    "prettier": "catalog:",
    "rimraf": "catalog:",
    "simple-git-hooks": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "tsx": "catalog:"
  }
}
